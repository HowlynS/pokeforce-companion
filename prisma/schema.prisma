// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One release of the game, managed by admins in the secondary settings area
// ("Game Version" is the only contributor-facing term — never "build").
// Verification stamps on gameplay data reference a row here relationally;
// the row marked isCurrent is the single source of truth for "the current
// game version" (this replaced the CURRENT_GAME_BUILD_ID environment
// variable in Slice 9A). "At most one current" is enforced by the
// service-layer transaction in src/lib/game-versions.ts — every path that
// sets isCurrent unsets the previous current row in the same transaction.
// Deleting a version that any verification stamp still references is
// blocked both by the admin action's pre-check and by the database itself
// (every verifiedGameVersionId relation below is onDelete: Restrict), so
// historical verification stamps can never be orphaned or silently
// detached.
model GameVersion {
  id                         String              @id @default(cuid())
  name                       String              @unique
  releaseDate                DateTime?
  isCurrent                  Boolean             @default(false)
  verifiedItems              Item[]
  verifiedLocations          Location[]
  verifiedAcquisitionSources AcquisitionSource[]
  verifiedRecipes            Recipe[]
  verifiedProfessions        Profession[]
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  items       Item[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Item {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  description        String?
  image              String?
  heldItem           Boolean             @default(false)
  tradeable          Boolean             @default(false)
  baseValue          Int?
  categoryId         String?
  category           Category?           @relation(fields: [categoryId], references: [id])
  recipesProduced    Recipe[]            @relation("RecipeResultItem")
  recipeIngredients  RecipeIngredient[]
  acquisitionSources AcquisitionSource[]
  // Gameplay-verification metadata: stamped only by the explicit opt-in
  // "Mark gameplay data as verified for the current game version." action;
  // normal edits never touch these fields. The version reference is
  // relational (onDelete: Restrict), so a referenced GameVersion cannot be
  // deleted out from under a stamp.
  verifiedAt            DateTime?
  verifiedGameVersionId String?
  verifiedGameVersion   GameVersion? @relation(fields: [verifiedGameVersionId], references: [id], onDelete: Restrict)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([categoryId])
  @@index([verifiedGameVersionId])
}

model Profession {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  description        String?
  image              String?
  recipes            Recipe[]
  acquisitionSources AcquisitionSource[]
  // Gameplay-verification metadata (added in Slice 9A): stamped only by the
  // explicit opt-in "Mark gameplay data as verified for the current game
  // version." action; normal edits never touch these fields.
  verifiedAt            DateTime?
  verifiedGameVersionId String?
  verifiedGameVersion   GameVersion? @relation(fields: [verifiedGameVersionId], references: [id], onDelete: Restrict)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([verifiedGameVersionId])
}

model Recipe {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  image             String?
  resultingItemId   String
  resultingItem     Item               @relation("RecipeResultItem", fields: [resultingItemId], references: [id])
  resultingQuantity Int                @default(1)
  professionId      String?
  profession        Profession?        @relation(fields: [professionId], references: [id])
  requiredLevel     Int?
  ingredients       RecipeIngredient[]
  // Gameplay-verification metadata (added in Slice 9A): stamped only by the
  // explicit opt-in "Mark gameplay data as verified for the current game
  // version." action; normal edits never touch these fields.
  verifiedAt            DateTime?
  verifiedGameVersionId String?
  verifiedGameVersion   GameVersion? @relation(fields: [verifiedGameVersionId], references: [id], onDelete: Restrict)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([professionId])
  @@index([resultingItemId])
  @@index([verifiedGameVersionId])
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  itemId   String
  item     Item   @relation(fields: [itemId], references: [id])
  quantity Int

  @@unique([recipeId, itemId])
  @@index([recipeId])
  @@index([itemId])
}

enum LocationType {
  REGION
  ROUTE
  TOWN
  BUILDING
  DUNGEON
  SUB_AREA
  SPECIAL_AREA
}

model Location {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  type               LocationType
  parentId           String?
  // Named self-relation for the location hierarchy. onDelete: Restrict means
  // the database itself refuses to delete a location while any row still
  // references it as parentId — children are never silently detached, and
  // the admin action's own _count pre-check exists only to give a friendly
  // message before that database constraint would ever fire.
  parent             Location?           @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children           Location[]          @relation("LocationHierarchy")
  description        String?
  image              String?
  accessNote         String?
  acquisitionSources AcquisitionSource[]
  // Gameplay-verification metadata: stamped only by the explicit opt-in
  // "Mark gameplay data as verified for the current game version." action;
  // normal edits never touch these fields. The version reference is
  // relational (onDelete: Restrict), so a referenced GameVersion cannot be
  // deleted out from under a stamp.
  verifiedAt            DateTime?
  verifiedGameVersionId String?
  verifiedGameVersion   GameVersion? @relation(fields: [verifiedGameVersionId], references: [id], onDelete: Restrict)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([parentId])
  @@index([verifiedGameVersionId])
}

enum AcquisitionType {
  FORAGING
  FISHING
  FARMING
  CRAFTING
  MINING
  ARCHAEOLOGY
  COOKING
  CONSTRUCTION
  SMITHING
  NPC_OR_SHOP
  ENEMY_DROP
  REWARD
  CONTAINER
  EXCHANGE
  EVENT
  OTHER
}

// A restrained record of one way an Item can be obtained. Deliberately
// shallow: no drop rates, min/max quantities, conditions, or NPC catalogue —
// `sourceLabel` is free text so a value like "Seed Merchant" or "Vendor on
// Route 4" is valid without any named-NPC model existing.
model AcquisitionSource {
  id              String          @id @default(cuid())
  itemId          String
  // The source is meaningless without its item, so it is deleted along with
  // it — mirroring RecipeIngredient's ON DELETE CASCADE on its own Recipe.
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type            AcquisitionType
  locationId      String?
  // Optional relations: the acquisition fact survives losing its location
  // or profession, matching Item.categoryId / Recipe.professionId.
  location        Location?       @relation(fields: [locationId], references: [id], onDelete: SetNull)
  professionId    String?
  profession      Profession?     @relation(fields: [professionId], references: [id], onDelete: SetNull)
  sourceLabel     String?
  notes           String?
  quantity        String?
  // Gameplay-verification metadata: stamped only by the explicit opt-in
  // "Mark gameplay data as verified for the current game version." action;
  // normal edits never touch these fields. The version reference is
  // relational (onDelete: Restrict), so a referenced GameVersion cannot be
  // deleted out from under a stamp.
  verifiedAt            DateTime?
  verifiedGameVersionId String?
  verifiedGameVersion   GameVersion? @relation(fields: [verifiedGameVersionId], references: [id], onDelete: Restrict)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([itemId])
  @@index([locationId])
  @@index([professionId])
  @@index([verifiedGameVersionId])
}

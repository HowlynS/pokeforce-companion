# Copy this file to `.env` and fill in real values.
# Never commit `.env` — it is already listed in .gitignore.

# Prisma / Supabase Postgres connection string.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Supabase project API settings (Project Settings -> API in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# The only email allowed to access /admin. Must match the manually created
# Supabase Auth user exactly (case-insensitive comparison is applied).
ADMIN_EMAIL="admin@example.com"

# Note: CURRENT_GAME_BUILD_ID was retired in Milestone 9 Slice 9A. The
# current Game Version now lives in the database (GameVersion.isCurrent)
# and is managed at /admin/settings/game-versions. A leftover value in an
# existing .env is harmless — nothing reads it anymore.

# Template only — copy this file to `.env.test.local` and fill in values
# from the ISOLATED Supabase test project (intended name:
# pokeforce-companion-test). Never reuse development values from `.env`,
# and never commit `.env.test.local` — it is already ignored by the
# `.env.*.local` rule in .gitignore.

# Prisma connection string for the TEST project's Postgres database.
DATABASE_URL=

# The TEST project's API settings (Project Settings -> API in the Supabase
# dashboard). These must belong to the test project, never to development.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The manually created TEST admin account's email (case-insensitive match,
# same rule as development).
ADMIN_EMAIL=

# Test-only, server-side password for the TEST admin account, used by
# future authenticated tests. Never a development or personal password.
TEST_ADMIN_PASSWORD=

# Explicit isolation marker: the TEST project's reference ID from the
# Supabase dashboard. Future guarded commands will refuse to run unless
# DATABASE_URL and NEXT_PUBLIC_SUPABASE_URL both belong to this project.
SUPABASE_TEST_PROJECT_REF=

# Deterministic game build identifier for tests: assertions rely on this
# exact value, so keep it stable. Server-side only — never NEXT_PUBLIC_.
CURRENT_GAME_BUILD_ID=test-build-001
